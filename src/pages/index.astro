---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site';
import { getCollection } from 'astro:content';
import { categoryMeta, formatDate } from '../utils/categories';

const allPosts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const latestPosts = allPosts.slice(0, 4);
---

<BaseLayout
  title="Implanty Opole · Dentysta i implantolog premium — przewodnik pacjenta"
  description="Implanty zębów Opole — wskazania, technika, cennik 2026, all-on-4, sinus lift, periimplantitis. Niezależny przewodnik pacjenta. Treści przygotowuje lek. dent. Marcin Nowosielski M.Sc. RWTH Aachen, implantolog przyjmujący w klinice Mikrostomart Opole."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Przewodnik pacjenta · Opole · 2026</p>
      <h1>Implanty zębów Opole — dentysta &amp; implantolog premium</h1>
      <p class="lead">
        Niezależny przewodnik pacjenta o <strong>implantologii</strong>
        i <strong>stomatologii premium w Opolu</strong>. Wskazania, technika,
        cennik 2026, all-on-4, sinus lift, periimplantitis. Treści przygotowuje
        <strong>{site.author.honorificPrefix} {site.author.name}, {site.author.honorificSuffix} RWTH Aachen</strong>
        — implantolog i stomatolog przyjmujący w klinice
        <a href={site.clinic.url} rel="noopener">Mikrostomart</a> w Opolu.
      </p>
      <div class="hero-cta">
        <a class="btn-primary" href={site.clinic.bookingUrl} rel="noopener">Umów konsultację w Mikrostomart →</a>
        <a class="btn-outline" href="/implanty-zebow-opole">Wszystko o implantach</a>
      </div>
    </div>
  </section>

  <section class="container intro-grid">
    <article>
      <h2>Implanty zębów</h2>
      <p>
        Implant zęba to <strong>tytanowa lub cyrkonowa „śrubka" wszczepiana w kość szczęki</strong>,
        która pełni rolę naturalnego korzenia. Po wgojeniu (3–6 mies.) zakładamy
        na nią koronę protetyczną — pacjent odzyskuje pełną funkcję żucia
        i estetykę zęba własnego.
      </p>
      <a href="/implanty-zebow-opole">Pełen przewodnik o implantach →</a>
    </article>

    <article>
      <h2>Dentysta w Opolu — jak wybrać</h2>
      <p>
        Wybór dentysty w Opolu to nie tylko cena i lokalizacja. Liczą się
        <strong>kwalifikacje specjalisty, sprzęt</strong> (mikroskop, CBCT, laser),
        materiały premium oraz transparentny plan leczenia. Pełne kryteria oceny
        w osobnym przewodniku.
      </p>
      <a href="/dentysta-opole">Jak wybrać dentystę w Opolu →</a>
    </article>

    <article>
      <h2>Cennik implantów 2026</h2>
      <p>
        Implant z koroną w Opolu kosztuje obecnie <strong>3500–6500 PLN</strong>
        za pojedynczy ząb (system implantu + odbudowa). All-on-4 dla całego łuku:
        <strong>25 000–50 000 PLN</strong>. Czynniki ceny i porównanie z regionem
        w szczegółowym cenniku.
      </p>
      <a href="/cennik-implantow-opole">Cennik implantów Opole →</a>
    </article>
  </section>

  <section class="container pillar-links">
    <h2>Najważniejsze tematy</h2>
    <div class="pillar-grid">
      <a href="/implanty-zebow-opole" class="pillar">
        <span class="pillar-num">01</span>
        <h3>Implanty zębów Opole</h3>
        <p>Kompletny przewodnik — wskazania, etapy, czas leczenia, materiały, koszt.</p>
      </a>
      <a href="/dentysta-opole" class="pillar">
        <span class="pillar-num">02</span>
        <h3>Dentysta Opole</h3>
        <p>Jak wybrać dobrego dentystę w Opolu — kryteria, kwalifikacje, ranking pytań do gabinetu.</p>
      </a>
      <a href="/stomatolog-opole" class="pillar">
        <span class="pillar-num">03</span>
        <h3>Stomatolog Opole</h3>
        <p>Stomatologia ogólna i premium w Opolu — przegląd, profilaktyka, planowanie leczenia.</p>
      </a>
      <a href="/implantolog-opole" class="pillar">
        <span class="pillar-num">04</span>
        <h3>Implantolog Opole</h3>
        <p>Specjalista od implantów — czym różni się od ogólnego dentysty, jakie kwalifikacje wymagać.</p>
      </a>
      <a href="/cennik-implantow-opole" class="pillar">
        <span class="pillar-num">05</span>
        <h3>Cennik implantów</h3>
        <p>Ile kosztuje implant w Opolu 2026 — pełen rozkład cen, czynniki, alternatywy.</p>
      </a>
      <a href="/blog" class="pillar">
        <span class="pillar-num">06</span>
        <h3>Blog</h3>
        <p>Artykuły o implantologii i stomatologii — wszystkie tematy od podstaw po trudne przypadki.</p>
      </a>
    </div>
  </section>

  {latestPosts.length > 0 && (
    <section class="container latest-posts">
      <header class="section-header">
        <h2>Najnowsze artykuły</h2>
        <a class="see-all" href="/blog">Wszystkie →</a>
      </header>
      <ul class="post-grid">
        {latestPosts.map((post) => (
          <li>
            <article>
              <p class="post-meta">
                <span class="category">{categoryMeta[post.data.category].label}</span>
                <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
              </p>
              <h3><a href={`/blog/${post.id}`}>{post.data.title}</a></h3>
              <p>{post.data.description}</p>
            </article>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section class="container author-box">
    <div class="author-grid">
      <div>
        <p class="eyebrow">O autorze</p>
        <h2>{site.author.honorificPrefix} {site.author.name}, {site.author.honorificSuffix}</h2>
        <p>
          Lekarz dentysta, implantolog, <strong>M.Sc. RWTH Aachen</strong> (2021, z wyróżnieniem)
          — drugi w Polsce z tym tytułem. Wykładowca LA&amp;HA Symposium
          (Słowenia 2019, 2023; Polska 2022). Autor książki <em>„Własny gabinet"</em>
          (Czelej 2024). Prowadzi klinikę <a href={site.clinic.url} rel="noopener">Mikrostomart</a>
          w Opolu — w ofercie implanty zębów, all-on-4, endodoncja mikroskopowa,
          chirurgia stomatologiczna i stomatologia estetyczna.
        </p>
        <p>
          <a class="btn-outline" href="/o-autorze">Pełna biografia →</a>
          &nbsp;
          <a href={site.author.canonicalUrl} rel="noopener">Blog osobisty: nowosielski.pl →</a>
        </p>
      </div>
    </div>
  </section>

  <section class="cta-section">
    <div class="container">
      <h2>Konsultacja implantologiczna w Opolu</h2>
      <p>
        Planujesz uzupełnienie braku zęba implantem? Boisz się że nie masz wystarczająco
        kości? Masz periimplantitis i szukasz drugiej opinii? <strong>Konsultację
        umówisz w klinice Mikrostomart w Opolu</strong> — pełna ocena z CBCT,
        plan leczenia z wariantami i cennikiem.
      </p>
      <a class="btn-primary" href={site.clinic.bookingUrl} rel="noopener">Umów konsultację w Mikrostomart →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light));
    color: white;
    padding: 4rem 0 3.5rem;
    margin-bottom: 3rem;
  }
  .hero h1 { color: white; font-size: 3rem; margin-top: 0.5rem; line-height: 1.15; }
  .hero .lead { font-size: 1.1875rem; color: #d4ddd6; max-width: 56rem; margin: 1rem 0 2rem; }
  .hero .lead a { color: var(--color-accent); }
  .hero .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8125rem;
    color: var(--color-accent);
    margin: 0;
    font-weight: 700;
  }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .hero .btn-outline { color: var(--color-accent) !important; border-color: var(--color-accent); }
  .hero .btn-outline:hover { background: var(--color-accent); color: var(--color-primary) !important; }

  .intro-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-bottom: 4rem;
  }
  .intro-grid article {
    background: var(--color-card);
    padding: 1.75rem;
    border-radius: 6px;
    border-top: 3px solid var(--color-accent);
    box-shadow: 0 1px 3px rgba(31, 61, 54, 0.06);
  }
  .intro-grid article h2 { margin-top: 0; font-size: 1.25rem; }

  .pillar-links { margin-bottom: 4rem; }
  .pillar-links h2 { margin-bottom: 1.5rem; }
  .pillar-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }
  .pillar {
    background: var(--color-card);
    padding: 1.5rem;
    border-radius: 6px;
    text-decoration: none;
    color: var(--color-fg);
    border: 1px solid var(--color-border);
    transition: all 0.2s;
    display: block;
  }
  .pillar:hover { border-color: var(--color-accent); transform: translateY(-2px); box-shadow: 0 4px 12px rgba(31, 61, 54, 0.08); }
  .pillar-num {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--color-accent);
    letter-spacing: 0.1em;
  }
  .pillar h3 { margin: 0.5rem 0 0.5rem; font-size: 1.0625rem; color: var(--color-primary); }
  .pillar p { font-size: 0.9375rem; color: var(--color-muted); margin: 0; }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .section-header h2 { margin: 0; }
  .see-all { font-weight: 600; text-decoration: none; }
  .see-all:hover { text-decoration: underline; }

  .latest-posts { margin-bottom: 4rem; }
  .post-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
  }
  .post-grid > li {
    background: var(--color-card);
    padding: 1.5rem;
    border-radius: 6px;
    border-left: 3px solid var(--color-accent);
    box-shadow: 0 1px 3px rgba(31, 61, 54, 0.06);
  }
  .post-grid h3 { margin: 0.5rem 0 0.75rem; font-size: 1.125rem; }
  .post-grid h3 a { text-decoration: none; }
  .post-grid h3 a:hover { text-decoration: underline; }
  .post-meta {
    font-size: 0.75rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .category { color: var(--color-accent-dark); font-weight: 700; }
  .post-grid p { font-size: 0.9375rem; margin-bottom: 0; }

  .author-box {
    background: var(--color-card);
    padding: 2.5rem;
    border-radius: 8px;
    border-left: 4px solid var(--color-primary);
    margin-bottom: 4rem;
  }
  .author-box .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.75rem;
    color: var(--color-accent-dark);
    font-weight: 700;
    margin: 0;
  }
  .author-box h2 { margin-top: 0.5rem; }

  .cta-section {
    background: var(--color-primary);
    color: white;
    padding: 3rem 0;
    margin-top: 4rem;
  }
  .cta-section h2 { color: white; }
  .cta-section p { color: #d4ddd6; max-width: 56rem; font-size: 1.0625rem; }
</style>
